# Ignore dynasty-specfic config, but keep the default example
config/*.toml
!config/default.toml
!config/nicknames.toml

# Ignore Claude session data, but keep project settings and commands
.claude/*
!.claude/settings.json
!.claude/commands/

# Ignore database files
*.db

# Ignore build artifacts
__pycache__
.venv/
*.whl

# Ignore sandbox proxy CA cert (sandbox-specific, not needed in repo)
proxy-ca.crt

# Ignore git worktrees directory
.worktrees/
