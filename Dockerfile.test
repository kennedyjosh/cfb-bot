ARG PLATFORM=linux/amd64
FROM --platform=$PLATFORM python:3.13-slim

ARG HTTP_PROXY
ARG HTTPS_PROXY
ENV HTTP_PROXY=$HTTP_PROXY
ENV HTTPS_PROXY=$HTTPS_PROXY

# Optionally trust a sandbox proxy CA cert.
# Provided via --secret id=proxy_cert,src=proxy-ca.crt at build time.
# If the secret is absent (default on Mac/CI), this is a no-op.
RUN --mount=type=secret,id=proxy_cert,required=false \
    if [ -f /run/secrets/proxy_cert ]; then \
      apt-get update -q && apt-get install -y -q ca-certificates && \
      cp /run/secrets/proxy_cert /usr/local/share/ca-certificates/proxy-ca.crt && \
      update-ca-certificates; \
    fi

WORKDIR /app

COPY requirements.txt requirements-dev.txt ./
RUN pip install --no-cache-dir -r requirements.txt -r requirements-dev.txt

COPY . .

CMD ["pytest", "--tb=short", "-q"]
